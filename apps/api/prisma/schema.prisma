generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String             @id @default(uuid())
  type          OrganizationType
  name          String
  status        OrganizationStatus @default(active)
  ownerMemberId String?            @map("owner_member_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  members      Member[]
  wallet       EntitlementWallet?
  usageRecords UsageRecord[]
  clients      Client[]
  projects     Project[]
  auditLogs    AuditLog[]

  @@map("organizations")
}

model Role {
  id        String @id @default(uuid())
  code      String @unique
  name      String
  scopeType String @map("scope_type")

  members Member[]

  @@map("roles")
}

model Member {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  email          String       @unique
  roleId         String       @map("role_id")
  status         MemberStatus @default(active)
  lastLoginAt    DateTime?    @map("last_login_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@index([organizationId])
  @@index([roleId])
  @@map("members")
}

model EntitlementWallet {
  id             String        @id @default(uuid())
  organizationId String        @unique @map("organization_id")
  status         WalletStatus  @default(active)
  currency       String        @default("TOKEN")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  grants       EntitlementGrant[]

  @@index([organizationId])
  @@map("entitlement_wallets")
}

model EntitlementGrant {
  id                String     @id @default(uuid())
  walletId          String     @map("wallet_id")
  grantType         GrantType  @map("grant_type")
  grantName         String     @map("grant_name")
  sourceType        SourceType @map("source_type")
  quantityTotal     Decimal    @map("quantity_total")
  quantityAvailable Decimal    @map("quantity_available")
  priority          Int        @default(0)
  expiresAt         DateTime?  @map("expires_at")
  status            GrantStatus @default(active)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  wallet EntitlementWallet @relation(fields: [walletId], references: [id])
  usageRecords UsageRecord[]

  @@index([walletId])
  @@index([status])
  @@index([expiresAt])
  @@index([walletId, status, expiresAt])
  @@map("entitlement_grants")
}

model UsageRecord {
  id              String      @id @default(uuid())
  organizationId  String      @map("organization_id")
  projectId       String?     @map("project_id")
  grantId         String      @map("grant_id")
  usageType       UsageType   @map("usage_type")
  workflowContext String?     @map("workflow_context")
  quantityUsed    Decimal     @map("quantity_used")
  costAmount      Decimal?    @map("cost_amount")
  occurredAt      DateTime    @default(now()) @map("occurred_at")
  traceId         String      @map("trace_id")
  status          UsageStatus @default(consumed)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  grant        EntitlementGrant @relation(fields: [grantId], references: [id])
  project      Project?          @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([grantId])
  @@index([occurredAt])
  @@index([projectId, occurredAt])
  @@map("usage_records")
}

enum OrganizationType {
  platform
  park
  opc_team
  service_partner
}

enum OrganizationStatus {
  active
  inactive
}

enum MemberStatus {
  active
  inactive
  pending
}

enum WalletStatus {
  active
  inactive
}

enum GrantType {
  token
  model_coupon
  tool_coupon
  special_coupon
}

enum SourceType {
  park_grant
  promo
  purchase
  manual_adjustment
}

enum GrantStatus {
  active
  exhausted
  expired
  revoked
}

enum UsageType {
  token_call
  model_use
  tool_run
  manual_adjustment
}

enum UsageStatus {
  consumed
  reserved
  rolled_back
}

enum PeriodType {
  project_total
  weekly
  monthly
}

enum ClientStatus {
  active
  inactive
}

enum ProjectStatus {
  draft
  scoped
  in_progress
  pending_acceptance
  accepted
  archived
}

enum ScopeStatus {
  draft
  frozen
  superseded
}

enum ChangeType {
  scope_add
  scope_reduce
  schedule_change
  cost_change
}

enum ChangeOrderStatus {
  draft
  submitted
  approved
  rejected
}

enum DeliveryStatus {
  draft
  submitted
  under_review
  approved
  rejected
}

enum AcceptanceDecision {
  approved
  rejected
  needs_change
}

model Client {
  id            String       @id @default(uuid())
  organizationId String      @map("organization_id")
  name          String
  contactName   String?      @map("contact_name")
  contactEmail  String?      @map("contact_email")
  status        ClientStatus @default(active)
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  projects     Project[]

  @@index([organizationId])
  @@map("clients")
}

model Project {
  id              String        @id @default(uuid())
  organizationId  String        @map("organization_id")
  clientId        String        @map("client_id")
  name            String
  industryPack    String        @map("industry_pack")
  status          ProjectStatus @default(draft)
  budgetAmount    Decimal?      @map("budget_amount")
  startDate       DateTime?     @map("start_date")
  dueDate         DateTime?     @map("due_date")
  repoBindingId   String?       @map("repo_binding_id")
  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id])
  client            Client             @relation(fields: [clientId], references: [id])
  scopeVersions     ScopeVersion[]
  usageRecords      UsageRecord[]
  changeOrders      ChangeOrder[]
  deliveryPackages  DeliveryPackage[]
  acceptanceRecords AcceptanceRecord[]
  profitLedgers     ProfitLedger[]

  @@index([organizationId])
  @@index([clientId])
  @@map("projects")
}

model ScopeVersion {
  id            String      @id @default(uuid())
  projectId     String      @map("project_id")
  versionNo     Int         @map("version_no")
  scopeSummary  String      @map("scope_summary")
  quotedAmount  Decimal?    @map("quoted_amount")
  deliveryPlan  String?     @map("delivery_plan")
  status        ScopeStatus @default(draft)
  frozenAt      DateTime?   @map("frozen_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id])
  changeOrders ChangeOrder[]

  @@index([projectId])
  @@map("scope_versions")
}

model ChangeOrder {
  id             String             @id @default(uuid())
  projectId      String             @map("project_id")
  scopeVersionId String?            @map("scope_version_id")
  title          String
  changeType     ChangeType         @map("change_type")
  amountDelta    Decimal?           @map("amount_delta")
  description    String?
  status         ChangeOrderStatus  @default(draft)
  submittedAt    DateTime?          @map("submitted_at")
  resolvedAt     DateTime?          @map("resolved_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id])
  scopeVersion ScopeVersion? @relation(fields: [scopeVersionId], references: [id])

  @@index([projectId])
  @@index([scopeVersionId])
  @@map("change_orders")
}

model DeliveryPackage {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  versionNo       String         @map("version_no")
  title           String
  summary         String?
  status          DeliveryStatus @default(draft)
  artifactUrl     String?        @map("artifact_url")
  releaseProofUrl String?        @map("release_proof_url")
  createdBy       String         @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  project             Project              @relation(fields: [projectId], references: [id])
  acceptanceRecords   AcceptanceRecord[]

  @@index([projectId])
  @@map("delivery_packages")
}

model AcceptanceRecord {
  id                String             @id @default(uuid())
  projectId         String             @map("project_id")
  deliveryPackageId String             @map("delivery_package_id")
  clientMemberId    String?            @map("client_member_id")
  decision          AcceptanceDecision @map("decision")
  comment           String?
  createdAt         DateTime           @default(now()) @map("created_at")

  project         Project         @relation(fields: [projectId], references: [id])
  deliveryPackage DeliveryPackage @relation(fields: [deliveryPackageId], references: [id])

  @@index([projectId])
  @@index([deliveryPackageId])
  @@map("acceptance_records")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  memberId       String?  @map("member_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String
  payloadJson    String?  @map("payload_json")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model ProfitLedger {
  id                String      @id @default(uuid())
  projectId         String      @map("project_id")
  periodType        PeriodType  @map("period_type")
  tokenCostAmount   Decimal?    @map("token_cost_amount")
  toolCostAmount    Decimal?    @map("tool_cost_amount")
  laborCostAmount   Decimal?    @map("labor_cost_amount")
  otherCostAmount   Decimal?    @map("other_cost_amount")
  revenueAmount     Decimal?    @map("revenue_amount")
  grossProfitAmount Decimal?    @map("gross_profit_amount")
  grossMargin       Decimal?    @map("gross_margin")
  calculatedAt      DateTime    @default(now()) @map("calculated_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, periodType])
  @@index([projectId])
  @@index([projectId, periodType])
  @@map("profit_ledgers")
}
